# ===================================
# Aniq Hisob Platform - Environment
# ===================================

# Application
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://quvonchbek.me

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me-strong-password
DB_NAME=aniq_hisob

# JWT
JWT_SECRET=change-this-to-a-strong-secret-key-at-least-32-chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# WebSocket
WS_PORT=3001

# Payments
PAYMENT_MOCK_ENABLED=true
APP_BASE_URL=https://api.quvonchbek.me
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
PAYME_TEST_MODE=true
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_TEST_MODE=true
