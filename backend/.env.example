# ===================================
# Aniq Hisob Platform - Environment
# ===================================

# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=aniq_hisob

# JWT
JWT_SECRET=change-this-to-a-strong-secret-key
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# WebSocket
WS_PORT=3001
