# ===================================
# Aniq Hisob Platform - Environment
# ===================================

# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=aniq_hisob

# JWT
JWT_SECRET=change-this-to-a-strong-secret-key
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# WebSocket
WS_PORT=3001

# Payments
PAYMENT_MOCK_ENABLED=true
APP_BASE_URL=http://localhost:3000
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
PAYME_TEST_MODE=true
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_TEST_MODE=true
