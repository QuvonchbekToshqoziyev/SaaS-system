datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  ADMIN
  FIRM
}

enum FlightSettlementStatus {
  OPEN
  CLOSING
  CLOSED
}

enum TicketStatus {
  AVAILABLE
  PENDING
  ASSIGNED
  ALLOCATED
  SOLD
  CANCELLED
  REFUNDED
}

enum FirmStatus {
  ACTIVE
  SUSPENDED
}

enum TransactionType {
  ALLOCATION
  SALE
  PAYMENT
  REFUND
  ADJUSTMENT
  PAYABLE
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum ReconciliationStatus {
  PENDING
  MATCHED
  FAILED
}

enum KassaStatus {
  OPEN
  CLOSED
}

model User {
  id                              String                    @id @default(uuid())
  email                           String                    @unique
  password                        String
  role                            Role                      @default(FIRM)
  firmId                          String?
  firm                            Firm?                     @relation(fields: [firmId], references: [id])
  createdTransactions             Transaction[]             @relation("TransactionCreatedBy")
  createdSaleCancellationRequests SaleCancellationRequest[] @relation("SaleCancellationRequestCreatedBy")
  decidedSaleCancellationRequests SaleCancellationRequest[] @relation("SaleCancellationRequestDecidedBy")
  openedKassaDays                 KassaDay[]                @relation("KassaOpenedBy")
  closedKassaDays                 KassaDay[]                @relation("KassaClosedBy")
  createdAt                       DateTime                  @default(now())
  updatedAt                       DateTime                  @updatedAt
}

model Firm {
  id                       String                    @id @default(uuid())
  name                     String
  creditLimit              Decimal                   @default(0) @db.Decimal(12, 4)
  currency                 String                    @default("USD")
  status                   FirmStatus                @default(ACTIVE)
  users                    User[]
  tickets                  Ticket[]
  transactions             Transaction[]
  paidTransactions         Transaction[]             @relation("TransactionPayerFirm")
  receivedTransactions     Transaction[]             @relation("TransactionReceiverFirm")
  payments                 Payment[]
  invitations              Invitation[]
  saleCancellationRequests SaleCancellationRequest[]
  ownedTourPackages        TourPackage[]             @relation("TourPackageOwner")
  boughtTourPackageSales   TourPackageSale[]         @relation("TourPackageBuyer")
  soldTourPackageSales     TourPackageSale[]         @relation("TourPackageSeller")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model Invitation {
  id        String    @id @default(uuid())
  email     String
  firmId    String?
  firm      Firm?     @relation(fields: [firmId], references: [id])
  role      Role      @default(FIRM)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([firmId])
  @@index([createdBy])
  @@index([expiresAt])
  @@index([usedAt])
}

model Flight {
  id                       String                    @id @default(uuid())
  route                    String
  flightNumber             String
  departure                DateTime                  @map("departureTime")
  arrival                  DateTime?                 @map("arrivalTime")
  currency                 String
  settlementStatus         FlightSettlementStatus    @default(OPEN)
  status                   String?
  tickets                  Ticket[]
  transactions             Transaction[]
  saleCancellationRequests SaleCancellationRequest[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model Ticket {
  id                       String                    @id @default(uuid())
  flightId                 String
  flight                   Flight                    @relation(fields: [flightId], references: [id])
  status                   TicketStatus              @default(AVAILABLE)
  basePrice                Decimal                   @map("price") @db.Decimal(12, 4)
  currency                 String
  assignedFirmId           String?                   @map("allocatedFirmId")
  assignedFirm             Firm?                     @relation(fields: [assignedFirmId], references: [id])
  soldPrice                Decimal?                  @db.Decimal(12, 4)
  soldCurrency             String?
  purchaserInfo            Json?
  saleCancellationRequests SaleCancellationRequest[]
  transactions             Transaction[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  @@index([flightId, status])
  @@index([assignedFirmId, status])
  @@index([flightId, assignedFirmId])
}

model CurrencyRate {
  id             String   @id @default(uuid())
  baseCurrency   String
  targetCurrency String
  rate           Decimal  @db.Decimal(12, 6)
  source         String
  recordedAt     DateTime @default(now())
}

model Transaction {
  id              String          @id @default(uuid())
  type            TransactionType
  firmId          String
  firm            Firm            @relation(fields: [firmId], references: [id])
  flightId        String?
  flight          Flight?         @relation(fields: [flightId], references: [id])
  ticketId        String?
  ticket          Ticket?         @relation(fields: [ticketId], references: [id])
  payerFirmId     String?
  payerFirm       Firm?           @relation("TransactionPayerFirm", fields: [payerFirmId], references: [id])
  receiverFirmId  String?
  receiverFirm    Firm?           @relation("TransactionReceiverFirm", fields: [receiverFirmId], references: [id])
  direction       String?
  subjectType     String?
  subjectId       String?
  createdByUserId String?
  createdBy       User?           @relation("TransactionCreatedBy", fields: [createdByUserId], references: [id])
  originalAmount  Decimal         @db.Decimal(12, 4)
  currency        String
  exchangeRate    Decimal         @db.Decimal(12, 6)
  baseAmount      Decimal         @db.Decimal(12, 4)
  paymentMethod   String?
  idempotencyKey  String?         @unique
  metadata        Json?
  ledgerEntries   LedgerEntry[]
  tourPackageSale TourPackageSale?
  createdAt       DateTime        @default(now())

  @@index([firmId, createdAt])
  @@index([payerFirmId, createdAt])
  @@index([receiverFirmId, createdAt])
  @@index([flightId, createdAt])
  @@index([subjectType, subjectId])
  @@index([type, createdAt])
  @@index([currency, createdAt])
  @@index([paymentMethod, createdAt])
  @@index([createdByUserId, createdAt])
}

model TourPackage {
  id                String            @id @default(uuid())
  ownerFirmId       String
  ownerFirm         Firm              @relation("TourPackageOwner", fields: [ownerFirmId], references: [id])
  name              String
  destination       String
  startDate         DateTime?
  endDate           DateTime?
  quantity          Int
  availableQuantity Int
  unitPrice         Decimal           @db.Decimal(12, 4)
  currency          String            @default("UZS")
  status            String            @default("ACTIVE")
  notes             String?
  sales             TourPackageSale[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([ownerFirmId, status])
  @@index([destination])
}

model TourPackageSale {
  id            String       @id @default(uuid())
  packageId     String
  package       TourPackage  @relation(fields: [packageId], references: [id])
  sellerFirmId  String
  sellerFirm    Firm         @relation("TourPackageSeller", fields: [sellerFirmId], references: [id])
  buyerFirmId   String
  buyerFirm     Firm         @relation("TourPackageBuyer", fields: [buyerFirmId], references: [id])
  quantity      Int
  unitPrice     Decimal      @db.Decimal(12, 4)
  currency      String
  totalAmount   Decimal      @db.Decimal(12, 4)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  notes         String?
  createdAt     DateTime     @default(now())

  @@index([packageId, createdAt])
  @@index([sellerFirmId, createdAt])
  @@index([buyerFirmId, createdAt])
}

model LedgerEntry {
  id                   String      @id @default(uuid())
  transactionId        String
  transaction          Transaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  debitAccount         String
  creditAccount        String
  amount               Decimal     @db.Decimal(12, 4)
  currency             String
  exchangeRateSnapshot Decimal     @db.Decimal(12, 6)
  createdAt            DateTime    @default(now())

  @@index([transactionId])
  @@index([debitAccount])
  @@index([creditAccount])
  @@index([createdAt])
}

model Payment {
  id                   String               @id @default(uuid())
  firmId               String
  firm                 Firm                 @relation(fields: [firmId], references: [id])
  amount               Decimal              @db.Decimal(12, 4)
  method               PaymentMethod
  reference            String?
  status               PaymentStatus        @default(PENDING)
  reconciliationStatus ReconciliationStatus @default(PENDING)
  createdAt            DateTime             @default(now())

  @@index([firmId, status])
  @@index([reconciliationStatus])
  @@index([createdAt])
}

model KassaDay {
  id               String      @id @default(uuid())
  businessDate     DateTime    @db.Date
  status           KassaStatus @default(OPEN)
  openedAt         DateTime    @default(now())
  openedByUserId   String
  openedBy         User        @relation("KassaOpenedBy", fields: [openedByUserId], references: [id])
  closedAt         DateTime?
  closedByUserId   String?
  closedBy         User?       @relation("KassaClosedBy", fields: [closedByUserId], references: [id])
  openingBalance   Decimal     @default(0) @db.Decimal(12, 4)
  closingBalance   Decimal?    @db.Decimal(12, 4)
  expectedCash     Decimal?    @db.Decimal(12, 4)
  variance         Decimal?    @db.Decimal(12, 4)
  notes            String?

  @@unique([businessDate])
  @@index([status])
  @@index([businessDate, status])
}

model SaleCancellationRequest {
  id              String    @id @default(uuid())
  flightId        String
  flight          Flight    @relation(fields: [flightId], references: [id])
  ticketId        String
  ticket          Ticket    @relation(fields: [ticketId], references: [id])
  firmId          String
  firm            Firm      @relation(fields: [firmId], references: [id])
  status          String    @default("PENDING")
  reason          String
  decisionReason  String?
  createdByUserId String
  createdBy       User      @relation("SaleCancellationRequestCreatedBy", fields: [createdByUserId], references: [id])
  decidedByUserId String?
  decidedBy       User?     @relation("SaleCancellationRequestDecidedBy", fields: [decidedByUserId], references: [id])
  decidedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([flightId, status])
  @@index([ticketId, status])
  @@index([firmId, status])
  @@index([createdByUserId])
  @@index([decidedByUserId])
}
