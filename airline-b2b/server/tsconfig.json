{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node10",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "preserveSymlinks": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "zod": ["node_modules/zod"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*", "prisma/**/*.ts"]
}
